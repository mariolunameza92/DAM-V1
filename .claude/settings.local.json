{
  "permissions": {
    "allow": [
      "Bash(node .claude/server.js*)",
      "Bash(lsof -ti :3000 :3001 2>/dev/null | xargs kill -9 2>/dev/null*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3000*)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3001*)",
      "mcp__Claude_Preview__preview_start",
      "mcp__862e49d2-99a7-4a51-b0da-40cd03d6e7f9__get_design_context",
      "mcp__862e49d2-99a7-4a51-b0da-40cd03d6e7f9__get_screenshot",
      "Bash(ls /Users/lenadmin/.nvm/versions/node/ 2>/dev/null | tail -1)",
      "PowerShell(Get-Command npx -ErrorAction SilentlyContinue)",
      "PowerShell(Get-Command python -ErrorAction SilentlyContinue)",
      "PowerShell(Get-Command python3 -ErrorAction SilentlyContinue)",
      "PowerShell(\\(Get-Command node\\).Source)",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(git commit --amend -m ' *)",
      "Bash(grep -vE \"^\\\\s*$|^commit|^Author|^Date\")",
      "Bash(grep -vE \":[ ]?0$\")",
      "Read(//Users/lenadmin/.nvm/versions/**)",
      "Read(//opt/homebrew/bin/**)",
      "Bash(echo \"exit:$?\")",
      "Bash(python3 -m http.server 3000 --bind 127.0.0.1)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$s = git status --porcelain; if ($s) { git add -A; git commit -m \"auto: $(Get-Date -Format 'yyyy-MM-dd HH:mm')\" }",
            "shell": "powershell",
            "timeout": 30,
            "statusMessage": "Auto-commit..."
          },
          {
            "type": "command",
            "command": "s=$(git status --porcelain 2>/dev/null); if [ -n \"$s\" ]; then git add -A && git commit -m \"auto: $(date '+%Y-%m-%d %H:%M')\"; fi",
            "shell": "bash",
            "timeout": 30,
            "statusMessage": "Auto-commit..."
          }
        ]
      }
    ]
  }
}
